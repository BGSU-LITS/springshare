{
    "name": "bgsu-lits/springshare",
    "description": "Springshare API Clients including LibAnswers.",
    "license": "MIT",
    "authors": [
        {
            "name": "John Kloor",
            "email": "kloor@bgsu.edu"
        }
    ],
    "require": {
        "php": "^8.2",
        "cuyz/valinor": "^2.4",
        "psr/cache": "^3.0",
        "psr/simple-cache": "^3.0",
        "saloonphp/cache-plugin": "^3.0",
        "saloonphp/saloon": "^4.0",
        "symfony/cache": "^7.2"
    },
    "require-dev": {
        "carthage-software/mago": "^1.28.0",
        "phpunit/phpunit": "^11",
        "roave/security-advisories": "dev-master",
        "symfony/var-dumper": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Lits\\Springshare\\": "src"
        },
        "exclude-from-classmap": [
            "/src/Test/"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyze": "mago --config mago.toml analyze",
        "check": "mago --config mago.toml format --dry-run",
        "format": "mago --config mago.toml format",
        "lint": "mago --config mago.toml lint",
        "post-install-cmd": [
            "@reset-cache"
        ],
        "post-update-cmd": [
            "@reset-cache"
        ],
        "phpunit": "phpunit -c phpunit.xml",
        "reset-cache": "rm -rf ./cache/*",
        "test": [
            "@lint",
            "@analyze",
            "@check",
            "@phpunit"
        ]
    },
    "scripts-descriptions": {
        "analyze": "Analyze PHP code with Mago.",
        "check": "Check PHP formatting with Mago.",
        "format": "Format PHP code with Mago.",
        "lint": "Lint PHP code with Mago.",
        "phpunit": "Run PHPUnit tests.",
        "reset-cache": "Resets the application by deleting all cache files.",
        "test": "Perform all available tests."
    }
}
