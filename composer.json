{
    "name": "bgsu-lits/springshare",
    "description": "Springshare API Clients including LibAnswers.",
    "license": "MIT",
    "authors": [
        {
            "name": "John Kloor",
            "email": "kloor@bgsu.edu"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/cache": "^3.0",
        "psr/simple-cache": "^3.0",
        "saloonphp/cache-plugin": "^3.0",
        "saloonphp/saloon": "^3.0",
        "symfony/cache": "^7.2"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.3",
        "neronmoon/scriptsdev": "^0.1.9",
        "phpunit/phpunit": "^11",
        "roave/security-advisories": "dev-master",
        "symfony/var-dumper": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Lits\\Springshare\\": "src"
        },
        "exclude-from-classmap": [
            "/src/Test/"
        ]
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "neronmoon/scriptsdev": true
        },
        "sort-packages": true
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": true
        },
        "scripts-dev": {
            "phpcbf": "phpcbf ./ --standard=phpcs.xml",
            "phpcs": "phpcs ./ --standard=phpcs.xml",
            "phplint": "phplint ./ -c phplint.yml",
            "phpstan": "phpstan analyse -c phpstan.neon",
            "phpunit": "phpunit -c phpunit.xml",
            "psalm": "psalm --config=psalm.xml",
            "test": [
                "@phplint",
                "@phpcs",
                "@phpstan",
                "@psalm",
                "@phpunit"
            ]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@reset-cache"
        ],
        "post-update-cmd": [
            "@reset-cache"
        ],
        "reset-cache": "rm -rf ./cache/*"
    },
    "scripts-descriptions": {
        "reset-cache": "Resets the application by deleting all cache files."
    }
}
